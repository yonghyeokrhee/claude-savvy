# RDS 연결 설정 예시 파일
# 이 파일을 복사해서 rds.env로 만들고 실제 값을 입력하세요.
# rds.env는 .gitignore로 제외됩니다.
#
# cp config/rds.env.example config/rds.env

RDS_HOST=your-rds-endpoint.rds.amazonaws.com
RDS_PORT=3306
RDS_DATABASE=your_database_name
RDS_USER=your_username
RDS_PASSWORD=your_password

# SSL 인증서 경로 (선택사항)
# SSL_CA_PATH=/etc/ssl/cert.pem
